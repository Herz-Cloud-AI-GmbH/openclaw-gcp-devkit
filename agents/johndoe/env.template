# John Doe — Agent-Specific Configuration
# Copy to .env and fill in values before deploying.

# WhatsApp number for this agent (E.164 format, e.g. +4911111111)
# Each agent can have its own dedicated WhatsApp number.
# WHATSAPP_NUMBER=+4911111111

# Comma-separated E.164 numbers allowed to DM this agent
# WHATSAPP_ALLOW_FROM=+492222222

# Comma-separated WhatsApp group JIDs this agent may participate in
# (find group JIDs via openclaw channels status or WhatsApp Web debug)
# WHATSAPP_GROUPS=120363424282127706@g.us

# Comma-separated E.164 numbers allowed to trigger this agent in groups
# WHATSAPP_GROUP_ALLOW_FROM=+492222222
