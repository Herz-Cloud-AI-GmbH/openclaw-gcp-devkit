# OpenClaw Gateway Configuration
# ===============================
# Copy this file to config/.env and fill in at least one LLM provider key.
# This file configures the shared gateway. Agent-specific settings
# (WhatsApp numbers, channel policies) live in agents/<id>/env.template.
#
# Only ONE provider is required. Anthropic Claude is recommended.

# --- Gateway (auto-generated on first boot; override here if needed) ---
# OPENCLAW_GATEWAY_TOKEN=<your-token>

# --- Keyring password (protects stored OAuth tokens / secrets) ---
# GOG_KEYRING_PASSWORD=<random-hex>

# --- Anthropic Claude (recommended) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI GPT ---
# OPENAI_API_KEY=sk-...

# --- Google Gemini ---
# GOOGLE_GENERATIVE_AI_API_KEY=...

# --- KIMI K2.5 (Moonshot AI) ---
# MOONSHOT_API_KEY=sk-...

# --- GitHub Copilot (uses your GitHub token with Copilot subscription) ---
# GITHUB_TOKEN=ghp-...
